---
import ServiceCard from './ServiceCard.astro';

const services = [
  {
    title: 'AI Agents & Agentic Applications',
    description:
      'Design and development of autonomous AI agents and multi-agent systems — personal assistants, agentic workflows, and intelligent automation.',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="4" r="2.5"/><circle cx="4" cy="16" r="2.5"/><circle cx="16" cy="16" r="2.5"/><line x1="8.5" y1="6" x2="5.5" y2="14"/><line x1="11.5" y1="6" x2="14.5" y2="14"/><line x1="6.5" y1="16" x2="13.5" y2="16"/></svg>',
  },
  {
    title: 'LLM Applications',
    description:
      'End-to-end development of LLM-powered applications — chatbots, document processing pipelines, and intelligent search systems.',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="4" cy="4" r="2.5"/><circle cx="16" cy="4" r="2.5"/><circle cx="10" cy="16" r="2.5"/><line x1="6" y1="5.5" x2="8.5" y2="14"/><line x1="14" y1="5.5" x2="11.5" y2="14"/><line x1="6.5" y1="4" x2="13.5" y2="4"/></svg>',
  },
  {
    title: 'NLP & Machine Learning',
    description:
      'Custom models tailored to your data — classification, extraction, generation, semantic search. Trained and deployed for your specific domain.',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 10C3 4 5 4 7 10S11 16 13 10S17 4 19 10"/></svg>',
  },
  {
    title: 'AI Strategy & Consulting',
    description:
      'Guidance on AI adoption, model selection, and architecture design to ensure you invest in the right technology.',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M2 4Q10 20 18 4"/><circle cx="10" cy="13" r="1.5" fill="currentColor" stroke="none"/></svg>',
  },
];
---

<section id="services" class="py-24 md:py-32 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="reveal">
      <p class="text-xs tracking-[0.25em] uppercase text-gold/50 font-medium">What We Do</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-serif font-semibold text-text">Services</h2>
    </div>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      {services.map((service) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          icon={service.icon}
        />
      ))}
    </div>
  </div>
</section>
