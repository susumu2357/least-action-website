<section id="contact" class="py-24 md:py-32 px-6">
  <div class="max-w-xl mx-auto">
    <div class="reveal">
      <p class="text-xs tracking-[0.25em] uppercase text-gold/50 font-medium">Get in Touch</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-serif font-semibold text-text">Contact</h2>
      <p class="mt-4 text-text-muted">
        Interested in working together? Send a message and I'll get back to you.
      </p>
    </div>

    <form
      action="https://api.web3forms.com/submit"
      method="POST"
      class="reveal mt-10 space-y-6"
    >
      <input type="hidden" name="access_key" value="4b3abb1d-1669-498a-8b08-1b7b461d47f2" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

      <div>
        <label for="name" class="block text-sm font-medium text-text">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="mt-1.5 w-full px-4 py-2.5 bg-bg-card border border-border rounded-card text-text placeholder-text-muted/40 focus:outline-none focus:ring-2 focus:ring-gold/30 focus:border-gold/40 transition-colors"
          placeholder="Your name"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-text">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="mt-1.5 w-full px-4 py-2.5 bg-bg-card border border-border rounded-card text-text placeholder-text-muted/40 focus:outline-none focus:ring-2 focus:ring-gold/30 focus:border-gold/40 transition-colors"
          placeholder="you@example.com"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-text">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="mt-1.5 w-full px-4 py-2.5 bg-bg-card border border-border rounded-card text-text placeholder-text-muted/40 focus:outline-none focus:ring-2 focus:ring-gold/30 focus:border-gold/40 transition-colors resize-y"
          placeholder="Tell me about your project..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full px-8 py-3.5 bg-gold/90 text-bg font-medium rounded-card hover:bg-gold transition-colors duration-300"
      >
        Send message
      </button>
    </form>
  </div>
</section>
