---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="reveal group bg-bg-card border border-border rounded-card p-7 hover:border-gold/20 transition-all duration-300">
  <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-gold/10 text-gold mb-5">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-lg font-semibold text-text group-hover:text-gold transition-colors duration-300">
    {title}
  </h3>
  <p class="mt-3 text-sm text-text-muted leading-relaxed">{description}</p>
</div>
